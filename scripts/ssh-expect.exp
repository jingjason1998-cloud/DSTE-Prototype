#!/usr/bin/expect -f
set timeout 30
set password [lindex $argv 0]
set host [lindex $argv 1]
set cmd [lindex $argv 2]

spawn ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null root@$host $cmd
expect {
    "password:" {
        send "$password\r"
        exp_continue
    }
    "Permission denied" {
        puts "Authentication failed"
        exit 1
    }
    eof
}
catch wait result
exit [lindex $result 3]
