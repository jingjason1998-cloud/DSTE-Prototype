{
  "name": "dste-platform",
  "private": true,
  "version": "0.4.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/generate-roadmap.cjs && vite build",
    "preview": "vite preview",
    "check:scope": "node scripts/check-onclick-scope.js src/cockpit.html && node scripts/check-onclick-scope.js src/business-topics.html",
    "health:check": "node scripts/health-check.cjs",
    "lint": "eslint .",
    "lint:security": "eslint . --format json --output-file eslint-report.json",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "deploy": "node scripts/deploy.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.40",
    "eslint": "^8.57",
    "eslint-plugin-html": "^8.1.4",
    "eslint-plugin-security": "^1.7",
    "vite": "^5.0"
  }
}
