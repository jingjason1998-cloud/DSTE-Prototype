{
  "name": "dste-platform",
  "private": true,
  "version": "0.6.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/generate-roadmap.cjs && vite build",
    "preview": "vite preview",
    "check:scope": "node scripts/check-onclick-scope.js src/cockpit.html && node scripts/check-onclick-scope.js src/business-topics.html && node scripts/check-onclick-scope.js src/meetings.html",
    "health:check": "node scripts/health-check.cjs",
    "lint": "eslint .",
    "lint:security": "eslint . --format json --output-file eslint-report.json",
    "check:deadcode": "knip",
    "check:deadcode:ci": "knip --max-issues 0",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.40",
    "esbuild": "^0.28.1",
    "eslint": "^8.57.1",
    "eslint-plugin-html": "^8.1.4",
    "eslint-plugin-security": "^1.7",
    "globals": "^17.6.0",
    "knip": "^5.88.1",
    "prettier": "^3.8.4",
    "vite": "^6.4.3",
    "vitest": "^4.1.8",
    "wrangler": "^3.80.0",
    "xlsx": "^0.18.5"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
